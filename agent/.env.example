# Token compartilhado com a central (precisa ser IGUAL ao INGEST_TOKEN do manager).
# A central usa este token para autenticar ao buscar as capturas neste agente.
INGEST_TOKEN=troque-este-token

# Identificador deste servidor no painel. Em branco = hostname da máquina.
AGENT_ID=

# Porta da API do agente (a central conecta aqui). Fica em 0.0.0.0.
AGENT_PORT=4000

# Modo do agente: ssh | web | net | both (ssh+web) | all (ssh+web+net). Combos: "ssh,net".
AGENT_MODE=ssh

# --- modo NET: sensor de rede via tcpdump (exige tcpdump instalado + root) ---
# Interface (any = todas). Filtro BPF customizado opcional (vazio = SYNs de entrada).
NET_IFACE=any
NET_FILTER=
NET_IGNORE=127.0.0.1,::1

# --- modo WEB: monitoramento de logs de acesso ---
# Caminhos dos access.log (auto-detecta nginx/apache/JSON). Separe por vírgula.
# Em branco = tenta os padrões comuns (/var/log/nginx/access.log, apache2, httpd...).
WEB_LOGS=
# IPs a ignorar (o próprio IP da central, ranges internos). CIDR não; use prefixo/substring.
WEB_IGNORE=127.0.0.1,::1

# Porta onde o honeypot SSH falso vai escutar (22 = padrão, exige root/sudo). Fica em 0.0.0.0.
HONEYPOT_PORT=22

# Banner SSH apresentado aos bots (imita um servidor real).
BANNER=SSH-2.0-OpenSSH_8.9p1 Ubuntu-3ubuntu0.1

# Tentativas de auth aceitas por sessão antes de derrubar a conexão.
MAX_AUTH_TRIES=6

# Máximo de capturas mantidas em memória no agente.
MAX_BUFFER=20000

# --- SEGURANÇA: auto-update remoto (a central grava e EXECUTA código novo aqui) ---
# DESLIGADO por padrão. Só ligue (=1) se confia na central E liberou a porta deste
# agente APENAS para o IP da central. Com =0, atualize o agente manualmente.
AUTO_UPDATE=0
