# ============================================================
#  THREATSCOPE — central (manager)
#  A configuração agora vive na INTERFACE (botão ⚙ CONFIG no dashboard),
#  salva dentro da própria base. Este arquivo é OPCIONAL e serve apenas de
#  SEMENTE na primeira execução — depois disso a UI é a fonte da verdade.
# ============================================================

# Único parâmetro que precisa ficar aqui: onde a base é gravada.
# (a config mora dentro da base, então precisamos saber a base antes de lê-la)
# Em branco = ~/.threatscope/threatscope.db  (instalações antigas seguem em ~/.sshoney)
# DB_PATH=/caminho/personalizado/threatscope.db

# ---- Abaixo: SEMENTES opcionais (só valem no 1º boot; depois edite em ⚙ CONFIG) ----
# API_PORT=4000
# POLL_MS=5000
# CORS_ORIGIN=*
# INGEST_TOKEN=troque-este-token
# GEOIP_DISABLE=0
# GEO_TTL_DAYS=30
# ABUSEIPDB_KEY=
# DISABLE_AUTOBLOCK=0
# PUBLIC_URL=
